<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_height"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/region_text"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingStart="56dp"
            android:text="@string/region_choose_text"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size"
            tools:ignore="RtlSymmetry,SpUsage" />

        <ImageButton
            android:id="@+id/return_button"
            android:layout_width="@dimen/button_size"
            android:layout_height="@dimen/button_size"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/merge_size"
            android:background="@null"
            android:src="@drawable/arrow_back_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="RtlHardcoded" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/search_edit_text"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/background_search_edit_text"
            android:drawableRight="@drawable/search_icon"
            android:drawablePadding="8dp"
            android:fontFamily="@font/ys_display_regular"
            android:hint="@string/input_region"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:textAppearance="@style/textAppearanceRegular16sp400w"
            android:textColor="@color/black"
            android:textColorHint="?attr/hint_color_edit_text"
            android:textCursorDrawable="@drawable/cursor" />

        <ImageView
            android:id="@+id/clear_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="14dp"
            android:background="?attr/attr_gray_light_gray_color"
            android:clickable="true"
            android:contentDescription="@string/contentDescription"
            android:focusable="true"
            android:src="@drawable/close_edit_text_search"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </FrameLayout>

    <!-- Состояние загрузки -->
    <LinearLayout
        android:id="@+id/loading_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Состояние ошибки -->
    <LinearLayout
        android:id="@+id/error_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="328dp"
            android:layout_height="223dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="Ошибка загрузки"
            android:src="@drawable/ic_no_internet" />

        <TextView
            android:id="@+id/error_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Не удалось получить список регионов"
            android:textAlignment="center"
            android:textColor="@color/black2"
            android:textSize="22sp" />

    </LinearLayout>

    <!-- Состояние "ничего не найдено" -->
    <LinearLayout
        android:id="@+id/no_results_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="328dp"
            android:layout_height="223dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="Ничего не найдено"
            android:src="@drawable/ic_no_results" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Такого региона нет"
            android:textAlignment="center"
            android:textColor="@color/black2"
            android:textSize="22sp" />

    </LinearLayout>

    <!-- Успешное состояние - список регионов -->
    <LinearLayout
        android:id="@+id/success_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/region_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

</LinearLayout>
