<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/attr_black_white_color"
    android:fitsSystemWindows="true">

    <!-- Заголовок -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_height"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/job_search_text"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/merge_size"
            android:text="@string/job_search"
            android:textColor="?attr/attr_white_black_color"
            android:textSize="@dimen/text_size"
            tools:ignore="RtlSymmetry" />

        <ImageButton
            android:id="@+id/trailing_button"
            android:layout_width="@dimen/button_size"
            android:layout_height="@dimen/button_size"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="@string/contentDescription"
            android:layout_marginEnd="@dimen/merge_size"
            android:background="@null"
            android:src="@drawable/trailing_icon" />
    </RelativeLayout>

    <!-- Основной контент -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="16dp">

        <!-- Основной контентный контейнер -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Поиск -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/search_container"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/rounded_search_background"
                android:padding="8dp">

                <EditText
                    android:id="@+id/search_edit_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/search_hint"
                    android:textColorHint="?attr/attr_gray_white_color"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@drawable/cursor"
                    android:textAppearance="@style/textAppearanceRegular16sp400w"
                    android:background="@android:color/transparent"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:paddingStart="12dp"
                    android:paddingEnd="40dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/search_icon" />

                <ImageView
                    android:id="@+id/search_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@drawable/search_icon"
                    android:contentDescription="@string/contentDescription"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <ImageView
                    android:id="@+id/clear_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/contentDescription"
                    android:src="@drawable/close_edit_text_search_24"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Количество результатов -->
            <TextView
                android:id="@+id/results_count_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_results_count"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:textAppearance="@style/textAppearanceRegular16sp400w"
                android:textColor="@color/white"
                android:visibility="gone" />

            <!-- RecyclerView для вакансий -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/vacancies_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Прогресс бар - поверх всего контента по центру -->
        <ProgressBar
            android:id="@+id/loading_progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/blue"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Состояние "нет интернета" -->
        <LinearLayout
            android:id="@+id/error_state_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="40dp"
            android:layout_marginBottom="48dp">

            <ImageView
                android:layout_width="328dp"
                android:layout_height="223dp"
                android:src="@drawable/ic_no_internet"
                android:contentDescription="@string/no_internet_content_description"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/error_state_text"
                style="@style/text_black_white_color"
                android:textAppearance="@style/textAppearanceMedium22sp500w"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_internet_title" />

        </LinearLayout>

        <!-- Состояние "нет результатов" -->
        <LinearLayout
            android:id="@+id/no_results_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="100dp">
            <!-- Текст "Ничего не найдено" НАД картинкой - на синем фоне -->

            <!-- Картинка 328x223 -->
            <ImageView
                android:layout_width="328dp"
                android:layout_height="223dp"
                android:src="@drawable/ic_no_results"
                android:contentDescription="@string/no_results_content_description"
                android:layout_marginBottom="16dp" />

            <!-- Дополнительный текст снизу -->
            <TextView
                android:id="@+id/no_results_subtitle"
                style="@style/text_black_white_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_results_subtitle"
                android:textSize="22sp"
                android:gravity="center"
                android:paddingStart="48dp"
                android:paddingEnd="48dp" />

        </LinearLayout>

        <!-- Состояние "пустой запрос" (изображение) -->
        <LinearLayout
            android:id="@+id/empty_state_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="72dp"
            android:visibility="visible">

            <ImageView
                android:id="@+id/empty_state_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/contentDescription"
                android:src="@drawable/il_1_1" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
