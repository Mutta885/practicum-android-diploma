<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/attr_black_white_color"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/title_height"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/work_place_text"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingStart="56dp"
            android:text="@string/country_choose_text"
            android:textColor="?attr/attr_white_black_color"
            android:textSize="@dimen/text_size"
            tools:ignore="RtlSymmetry,SpUsage" />

        <ImageButton
            android:id="@+id/return_button"
            android:layout_width="@dimen/button_size"
            android:layout_height="@dimen/button_size"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/merge_size"
            android:background="@null"
            android:contentDescription="@string/contentDescription"
            android:src="@drawable/arrow_back_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="RtlHardcoded" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/countries_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/no_results_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/not_region"
            android:textAlignment="center"
            android:layout_gravity="center"
            android:textAppearance="@style/textAppearanceMedium22sp500w"
            android:textColor="?attr/attr_white_black_color"
            android:textSize="22sp"
            android:visibility="visible"
            app:drawableTopCompat="@drawable/ic_no_results" />

        <FrameLayout
            android:id="@+id/loadingContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:indeterminateTint="@color/blue" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
